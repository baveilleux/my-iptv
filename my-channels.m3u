#EXTM3U x-tvg-url="https://iptv-org.github.io/epg/guides/us.xml"

#------------------------------------------------------------
# HOW THIS FILE WORKS
#
# Each channel = two lines:
#   Line 1: #EXTINF:-1 [metadata], Channel Name
#   Line 2: The stream URL
#
# To add a channel: copy any two-line block, change name/URL.
# To remove a channel: delete both lines.
#
# When a stream dies, find a replacement at:
#   https://github.com/iptv-org/iptv/blob/master/streams/us_samsung.m3u
#   (Ctrl+F the channel name, copy its two lines into your file)
#
# After editing on GitHub, VLC pulls the latest automatically.
#------------------------------------------------------------


