#EXTM3U x-tvg-url="https://iptv-org.github.io/epg/guides/us.xml"

#------------------------------------------------------------
# HOW THIS FILE WORKS
#
# Each channel = two lines:
#   Line 1: #EXTINF:-1 [metadata], Channel Name
#   Line 2: The stream URL
#
# To add a channel: copy any two-line block, change the name
#   and URL. That's it.
#
# To remove a channel: delete both lines for that entry.
#
# When a stream goes dead: find a replacement URL at
#   https://iptv-org.github.io/iptv/countries/us.m3u
#   (open in browser or text editor, search channel name)
#
# After editing on GitHub, VLC pulls the latest automatically
#   next time you open the network stream URL.
#------------------------------------------------------------


